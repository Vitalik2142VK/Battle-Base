  _prefab: {fileID: 5840985984099297550, guid: 8cae44ff708ebc24c9c24be3f58dde26, type: 3}
  _sprite: {fileID: 21300000, guid: dbc0bbc80a424714d8895de6cc315800, type: 3}
  _name:
    _ru:
      _text: "\u0422\u044F\u0436\u0451\u043B\u0430\u044F \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u044F"
    _en:
      _text: Heavy artillery
    _tr:
      _text: "A\u011F\u0131r top\xE7u"
  _description:
    _ru:
      _text: "<color=green>\u042D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
        \u043F\u0440\u043E\u0442\u0438\u0432:</color>\n- \u0442\u044F\u0436\u0451\u043B\u043E\u0439
        \u0442\u0435\u0445\u043D\u0438\u043A\u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430;\n-
        \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u044B\u0445 \u0446\u0435\u043B\u0435\u0439.\n\n<color=red>\u0423\u044F\u0437\u0432\u0438\u043C
        \u043F\u0435\u0440\u0435\u0434:</color>\n- \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0440\u0435\u043B\u044C\u043D\u044B\u043C
        \u043E\u0440\u0443\u0436\u0438\u0435\u043C."
    _en:
      _text: '<color=green>Effective against:</color>

        - heavy enemy equipment;

        -
        aerial targets.


        <color=red>Vulnerable to:</color>

        - rapid-fire
        weapons.'
    _tr:
      _text: "<color=green>Etkili oldu\u011Fu durumlar:</color>\n- d\xFC\u015Fman
        a\u011F\u0131r te\xE7hizat\u0131;\n- hava hedefleri.\n\n<color=red>Savunmas\u0131z
        oldu\u011Fu durumlar:</color>\n- h\u0131zl\u0131 silah."
  _price: 1500
