--- !u!114 &7394446734637031766
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2057367323769944926}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 129e5965baf964e41a4c3dc8cbf04850, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _popUp: {fileID: 7762814595804881608}
  _battleButton: {fileID: 1377008360203625931}
  _territoryName: {fileID: 4512214303687865087}
  _ownershipDescriptionText: {fileID: 734064314157636941}
  _playerOwnership:
    _ru:
      _text: "\u042D\u0442\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u044F
        \u0443\u0436\u0435 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
        \u0432\u0430\u043C. \u041D\u043E \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
        \u043F\u0440\u043E\u0439\u0442\u0438 \u0443\u0440\u043E\u0432\u0435\u043D\u044C
        \u0441\u043D\u043E\u0432\u0430, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C
        \u0431\u043E\u0435\u0432\u044B\u0435 \u043D\u0430\u0432\u044B\u043A\u0438"
    _en:
      _text: This territory already belongs to you. But you can complete the level
        again to boost your fighting skills
    _tr:
      _text: "Bu b\xF6lge zaten sizin.  Ama sava\u015F becerilerinizi geli\u015Ftirmek
        i\xE7in seviyeyi tekrar ge\xE7ebilirsiniz"
  _enemyOwnership:
    _ru:
      _text: "\u0412\u0440\u0430\u0436\u0435\u0441\u043A\u0430\u044F \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u044F.
        \u041D\u0435\u0442 \u0432\u0430\u0448\u0438\u0445 \u0432\u043E\u0439\u0441\u043A
        \u043F\u043E\u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438, \u0447\u0442\u043E\u0431\u044B
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C"
    _en:
      _text: Enemy territory. There are no troops nearby to attack
    _tr:
      _text: "D\xFC\u015Fman b\xF6lgesi. Yak\u0131nlarda sald\u0131racak birlikleriniz
        yok"
  _contestedOwnership:
    _ru:
      _text: "\u0412\u0440\u0430\u0436\u0435\u0441\u043A\u0430\u044F \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u044F.
        \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043D\u0430\u043F\u0430\u0441\u0442\u044C
        \u043D\u0430 \u043D\u0435\u0451, \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
        \u044D\u0442\u0438 \u0437\u0435\u043C\u043B\u0438 \u043F\u043E\u0434 \u0441\u0432\u043E\u0439
        \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C"
    _en:
      _text: Enemy territory. You can attack her to get these lands under your control
    _tr:
      _text: "D\xFC\u015Fman topraklar\u0131.  Ona sald\u0131rarak bu topraklar\u0131
        kontrol alt\u0131na alabilirsiniz"
