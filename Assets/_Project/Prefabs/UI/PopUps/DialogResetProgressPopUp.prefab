  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 000b96f8c6a8ed1498e25c2ac575815d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _texts:
    _ru:
      _text: "\u0412\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u044B, \u0447\u0442\u043E
        \u0445\u043E\u0442\u0438\u0442\u0435 \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C
        \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441? \u0418\u0433\u0440\u0430
        \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u043F\u0443\u0449\u0435\u043D\u0430
        \u0441 \u0441\u0430\u043C\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0430.
        \u0421\u043E\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u0435 \u043F\u043E\u043A\u0443\u043F\u043A\u0438
        \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F"
    _en:
      _text: Are you sure you want to reset the progress? The game will start from
        the beginning. Purchases made will be saved
    _tr:
      _text: "\u0130lerlemeyi s\u0131f\u0131rlamak istedi\u011Finizden emin misiniz?
        Oyun en ba\u015Ftan ba\u015Flat\u0131lacak. Yap\u0131lan sat\u0131n al\u0131mlar
        kaydedilecek"
