  m_text: "\u0412\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u044B, \u0447\u0442\u043E
    \u0445\u043E\u0442\u0438\u0442\u0435 \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441? \u0418\u0433\u0440\u0430 \u0431\u0443\u0434\u0435\u0442
    \u0437\u0430\u043F\u0443\u0449\u0435\u043D\u0430 \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
    \u043D\u0430\u0447\u0430\u043B\u0430. \u0421\u043E\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u0435
    \u043F\u043E\u043A\u0443\u043F\u043A\u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F"
